<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="View your Metallica Merch Store order history.">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <link rel="stylesheet" href="/public/css/main.css">
</head>
<body>
<%- include('./layout/navbar', { user }) %>

<div class="page-wrapper" style="padding-top:calc(var(--navbar-height) + 40px)">
  <div class="container" style="max-width:860px">
    <div class="page-header">
      <div>
        <h1 class="page-header-title">My Orders</h1>
        <p class="page-header-subtitle">Your Metallica merch order history</p>
      </div>
      <a href="/" class="btn btn-primary">🎸 Shop More</a>
    </div>

    <div id="orders-container">
      <div style="text-align:center;padding:60px 0">
        <div class="spinner"></div>
        <p style="color:var(--text-muted);margin-top:16px">Loading your orders...</p>
      </div>
    </div>
  </div>
</div>

<div class="toast-container"></div>
<script src="/public/js/main.js"></script>
<script>
  // Ensure token is synced from localStorage as cookie may not be fresh
  $(document).ready(function() {
    if (!window.Auth.isLoggedIn()) {
      window.location.href = '/login?redirect=/orders';
    }
  });
</script>
</body>
</html>
